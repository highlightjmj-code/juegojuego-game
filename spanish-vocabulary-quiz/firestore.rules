rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper to validate document ID format
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Score entity submissions
    function isValidScore(data) {
      return data.keys().hasAll(['nickname', 'character', 'score', 'level', 'xp', 'timestamp'])
        && data.keys().size() == 6
        && data.nickname is string
        && data.nickname.size() >= 1
        && data.nickname.size() <= 30
        && data.character is string
        && data.character.size() >= 1
        && data.character.size() <= 40
        && data.score is int
        && data.score >= 0
        && data.score <= 100
        && data.level is int
        && data.level >= 1
        && data.level <= 10
        && data.xp is int
        && data.xp >= 0
        && data.timestamp is timestamp;
    }

    // Validation for Word entity submissions (for bootstrapping vocabulary)
    function isValidWord(data) {
      return data.keys().hasAll(['spanish', 'korean'])
        && data.keys().size() == 2
        && data.spanish is string
        && data.spanish.size() >= 1
        && data.spanish.size() <= 100
        && data.korean is string
        && data.korean.size() >= 1
        && data.korean.size() <= 100;
    }

    // Rules for scores collection (used for live leaderboard)
    match /scores/{scoreId} {
      allow create: if isValidId(scoreId) && isValidScore(request.resource.data);
      allow read, list: if true;
      allow update, delete: if false;
    }

    // Rules for words collection (Spanish vocabulary bank database)
    match /words/{wordId} {
      allow create: if isValidId(wordId) && isValidWord(request.resource.data);
      allow read, list: if true;
      allow update, delete: if false;
    }
  }
}
